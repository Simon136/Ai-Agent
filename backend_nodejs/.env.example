# Node.js 环境变量配置
# 复制到 .env 文件中使用

# 服务器配置
NODE_ENV=development
PORT=5000
HOST=0.0.0.0
FRONTEND_URL=http://localhost:8080

# 数据库配置 (对应原Python配置)
SQLALCHEMY_DATABASE_USER=root
SQLALCHEMY_DATABASE_PASSWORD=your_password
SQLALCHEMY_DATABASE_URL=localhost
SQLALCHEMY_DATABASE_NAME=chat_ai
DB_PORT=3306

# JWT密钥 (对应原Python FLASK_KEY)
FLASK_KEY=your-secret-key

# AWS S3配置
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your_bucket_name

# Azure配置
AZURE_CLIENT_ID=your_azure_client_id
AZURE_AUTHORITY=your_azure_authority
AZURE_REDIRECT_URI=your_redirect_uri

# OpenAI配置
OPENAI_API_KEY=your_openai_api_key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORGANIZATION=your_organization_id

# Anthropic配置
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google配置
GOOGLE_API_KEY=your_google_api_key

# Azure OpenAI配置
AZURE_OPENAI_API_KEY=your_azure_openai_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# 日志配置
LOG_LEVEL=info
LOG_FORMAT=combined

# 安全配置
SESSION_SECRET=your-session-secret
CORS_ORIGINS=http://localhost:8080,https://yourdomain.com

# 生产环境额外配置
# NODE_ENV=production
# FRONTEND_URL=https://yourdomain.com
# LOG_LEVEL=warn
